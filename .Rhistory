library(tidyverse)
library(knitr)
library(gridExtra)
library(ggpubr)
setwd("E:\\Data Analysis\\Dr_Achangwa_Chiara\\1 Number of Offspring SK")
# df <- read_csv("C:/Users/ACHANGWA CHIARA/Desktop/datbirthrate.csv")
df <- read.csv("datbirthrate2.csv")
d70 <- data.frame(Date = 1970, Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_1970))
d75 <- data.frame(Date = 1975,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_1975))
d80 <- data.frame(Date = 1980,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_1980))
d85 <- data.frame(Date = 1985,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_1985))
d90 <- data.frame(Date = 1990,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_1990))
d2000 <- data.frame(Date = 2000,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_2000))
d2005 <- data.frame(Date = 2005,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_2005))
d2010 <- data.frame(Date = 2010,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_2010))
d2015 <- data.frame(Date = 2015,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_2015))
d2020 <- data.frame(Date = 2020,Number_of_kids = rep(df$Number_of_kids, time = df$Number_of_women_2020))
df2 <- rbind(d70, d75, d80, d85, d90, d2000, d2005, d2010, d2015, d2020) %>%
mutate(Date2 = ifelse(Date <= 1975, "1970 - 75", ifelse(Date <= 1990, "1980 - 1990", ifelse(Date <= 2010, "2000 - 2010", "2015 - 2020"))))
df2 <- rbind(d70, d75, d80, d85, d90, d2000, d2005, d2010, d2015, d2020) %>%
mutate(Date2 = ifelse(Date <= 1975, "1970 - 75", ifelse(Date <= 1990, "1980 - 1990", ifelse(Date <= 2010, "2000 - 2010", "2015 - 2020"))))
df3 <- df2[sample(seq(1, 41157481), 10000),]
Comp <- list(c("1970 - 75", "1980 - 1990"), c("1980 - 1990", "2000 - 2010"), c("2000 - 2010", "2015 - 2020"), c("1970 - 75", "2015 - 2020"), c("1980 - 1990", "2015 - 2020"), c("1970 - 75", "2000 - 2010"))
Notation <- list(cutpoints = c(0, 0.001, 0.01), symbols = c("p < 0.001", "**"))
p0 <-df3 %>%
ggplot(aes(x = Date2, y = Number_of_kids, fill = Date2))+
geom_boxplot()+
scale_fill_manual(values = c("#F4F4F4", "#F4BF6F", "#DC6826", "#9C3206"))+
labs(x = 'Period', y = "No. Offspring", title = "B")+
theme_classic()+
theme(legend.position = "none",
axis.text = element_text(size = 12, color = "black"),
axis.title = element_text(size = 14, face = "bold"),
axis.text.x = element_text(angle = 35, hjust = 1))+
scale_y_continuous(breaks = seq(0,20,2), labels= seq(0,20,2))+
stat_compare_means(comparisons = Comp,
p.adjust.method = "bonferroni",
method='wilcox.test',
label='p.adj.signif',
tip.length = c(0.01),
step.increase = 0.1,
symnum.args = Notation)
# ggsave("PairwiseComp.jpg", dpi = 600, width = 7.8, height = 5.29, units = "in")
d70_75 <- df2 %>% filter(Date <= 1975)
p1 <-  ggplot(d70_75, aes(x = Number_of_kids))+
geom_histogram(binwidth = 1, fill = "#F4F4F4", color = "black")+
geom_vline(xintercept = c(quantile(d70_75$Number_of_kids,.25), median(d70_75$Number_of_kids),
quantile(d70_75$Number_of_kids,.75)), size = 0.8,
linetype=c("dashed", "dotted", "dashed"), color = c("cadetblue", "brown3", "cadetblue"))+
scale_x_continuous(breaks = 0:10, labels= 0:10, expand =c(0,0))+
labs(x = "", y = "Count (Millions)", title = "A")+
scale_y_continuous(breaks = seq(0,7e+6,1e+6), labels= seq(0,7,1),expand =c(0,0), limits = c(0,7e+6))+
annotate("text", label = "1970 - 1975", x = 7, y = 6000000, color = "black")+
#annotate("text", label = "Newborns, n= 21 196 127", x = 7, y = 0.4, color = "black")+
#annotate("text", label = "Women, n= 7 312 811", x = 7, y = 0.3, color = "black")+
theme_classic()+
theme(axis.text = element_text(size = 12, color = "black"),
axis.title = element_text(size = 12, face = "bold"),
axis.text.x = element_blank(),
plot.title = element_text(size = 15, face = "bold"),
plot.margin = unit(c(0, 0, 0, 0), "cm"))
